{
  "name": "@ai-novel/server",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "main": "dist/app.js",
  "files": [
    "dist",
    "src/prisma/migrations",
    "src/prisma/migrations.sqlite",
    "src/prisma/schema.prisma",
    "src/prisma/schema.sqlite.prisma"
  ],
  "prisma": {
    "seed": "ts-node-dev --transpile-only src/db/seed.ts"
  },
  "scripts": {
    "dev": "pnpm run dev:api",
    "dev:api": "node scripts/ensure-dev-prisma.cjs && node scripts/stop-stale-dev-server.cjs && ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:director-worker": "node scripts/ensure-dev-prisma.cjs && ts-node-dev --respawn --transpile-only src/workers/directorWorker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "start:api": "node dist/app.js",
    "start:director-worker": "node dist/workers/directorWorker.js",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @ai-novel/shared build && pnpm run build && node --test tests/**/*.test.js",
    "test:planner": "pnpm --filter @ai-novel/shared build && pnpm run build && node --test tests/planner.test.js",
    "test:tools": "pnpm --filter @ai-novel/shared build && pnpm run build && node --test tests/tools.test.js",
    "test:runtime": "pnpm --filter @ai-novel/shared build && pnpm run build && node --test tests/runtime.test.js",
    "test:routes": "pnpm --filter @ai-novel/shared build && pnpm run build && node --test tests/routes.test.js",
    "test:book-analysis": "pnpm --filter @ai-novel/shared build && pnpm run build && node --test tests/bookAnalysis.test.js",
    "audit:director-recovery-samples": "node scripts/director-recovery-sample-audit.cjs",
    "prisma": "prisma",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --name init --config prisma.config.ts",
    "db:migrate": "pnpm prisma:migrate",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:restore": "node scripts/restore-dev-data.cjs"
  },
  "dependencies": {
    "@ai-novel/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.910.0",
    "@langchain/community": "^1.1.21",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "^7.4.2",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "langchain": "^1.2.28",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.3",
    "prisma": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
